APP_NAME=LocalApex
APP_ENV=production
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_DEBUG=false
DATABASE_URL=mysql+asyncmy://user:password@localhost:3306/localapex
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# AI (optional — enables AI review responses and Q&A suggestions)
OPENAI_API_KEY=

# Email notifications (optional — enables review alert emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=LocalApex
